{
  "entities": {
    "Itinerary": {
      "title": "Itinerary",
      "description": "A travel itinerary generated by AI",
      "type": "object",
      "properties": {
        "destination": { "type": "string", "description": "The travel destination" },
        "startDate": { "type": "string", "format": "date", "description": "Start date of the trip" },
        "endDate": { "type": "string", "format": "date", "description": "End date of the trip" },
        "budget": { "type": "string", "enum": ["economy", "moderate", "luxury"], "description": "Budget level" },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "User interests" },
        "content": { "type": "string", "description": "The generated itinerary content in markdown" },
        "userId": { "type": "string", "description": "The UID of the user who created this" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the itinerary was created" },
        "numericBudget": { "type": "string", "description": "Optional numeric budget" },
        "rating": { "type": "number", "description": "User rating for the itinerary" },
        "feedback": { "type": "string", "description": "User feedback for the itinerary" }
      },
      "required": ["destination", "startDate", "endDate", "budget", "content", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/itineraries/{itineraryId}": {
      "schema": "Itinerary",
      "description": "Collection of travel itineraries"
    }
  }
}
